{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter frontend build",
    "start": "pnpm --filter frontend start",
    "architecture-tests": "pnpm exec depcruise domain/src frontend/src",
    "test": "pnpm --filter pt-domain test && pnpm --filter frontend test",
    "tsc": "pnpm exec tsc --build",
    "tsc:watch": "pnpm exec tsc --build --watch",
    "prepare": "husky",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt",
    "knip": "knip"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "dependency-cruiser": "^17.4.3",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "syncpack": "^14.3.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm oxfmt",
      "pnpm oxlint --fix"
    ],
    "*.{json,md,css,less,html}": [
      "pnpm oxfmt"
    ]
  },
  "packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a"
}
